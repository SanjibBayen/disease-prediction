# API Configuration
API_TITLE=HealthPredict AI API
API_VERSION=3.0.0
API_DESCRIPTION=Advanced Disease Prediction System

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True
RELOAD=True

# Security
SECRET_KEY=your-secret-key-here-change-in-production
